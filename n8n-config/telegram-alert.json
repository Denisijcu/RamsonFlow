{
  "name": "RansomFlow — Telegram Alert",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "ransomflow-alert",
        "responseMode": "responseNode"
      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [240, 300],
      "webhookId": "ransomflow-webhook-001"
    },
    {
      "parameters": {
        "chatId": "={{ $env.TELEGRAM_CHAT_ID }}",
        "text": "=🔐 *RansomFlow Alert*\n\n*Event:* {{ $json.event }}\n*Workflow:* {{ $json.workflow }}\n*Target:* {{ $json.target }}\n*Timestamp:* {{ $json.timestamp }}\n\n{{ $json.message }}",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "name": "Telegram",
      "type": "n8n-nodes-base.telegram",
      "position": [480, 300],
      "credentials": { "telegramApi": { "id": "1", "name": "Telegram Bot" } }
    },
    {
      "parameters": { "respondWith": "json", "responseBody": "={\"ok\": true}" },
      "name": "Respond",
      "type": "n8n-nodes-base.respondToWebhook",
      "position": [720, 300]
    }
  ],
  "connections": {
    "Webhook": { "main": [[{ "node": "Telegram", "type": "main", "index": 0 }]] },
    "Telegram": { "main": [[{ "node": "Respond", "type": "main", "index": 0 }]] }
  },
  "active": true,
  "settings": {}
}
